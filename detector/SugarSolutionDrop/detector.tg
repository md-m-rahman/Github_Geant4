
:volu world BOX 500*cm 500*cm 500*cm G4_Galactic
:vis world OFF

:volu room BOX 300*cm 300*cm 300*cm G4_AIR
:vis room OFF
:rotm r000 0 0 0

:mixt_by_natoms G4_SUCROSE 1.05 3
  C 12
  H 360 
  O 180

:volu drop SPHERE 0 2*cm 0 180 0 90 G4_SUCROSE
:color drop 0.9 0.2 0.2

:volu HPGe TUBE 0 2*cm 3*cm G4_Ge
:color HPGe 0.5 0.5 0.5

:place room 1 world r000 0 0 0
:place drop 1 room r000 0 1*cm 0
:place HPGe 1 room r000 0 0 10*cm
